{
  "name": "utils-packages",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for utility packages",
  "scripts": {
    "build": "pnpm -r build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "changesets": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "serve . -l 3000"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.6",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
