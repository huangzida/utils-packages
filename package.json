{
  "name": "utils-packages",
  "version": "0.0.7",
  "private": true,
  "type": "module",
  "description": "Monorepo for utility packages",
  "scripts": {
    "build": "pnpm -r build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "release": "tsx scripts/release.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "serve . -l 3000"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "bumpp": "^9.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "prompts": "^2.4.2",
    "serve": "^14.2.6",
    "simple-git": "^3.33.0",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
